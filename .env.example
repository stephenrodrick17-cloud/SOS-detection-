# Environment Variables
# Database
DATABASE_URL=sqlite:///./infrastructure_damage.db
# For PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost/database_name

# Twilio Configuration (for SMS alerts)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1-555-0000

# SendGrid Configuration (for email alerts)
SENDGRID_API_KEY=your_sendgrid_key_here
SENDER_EMAIL=alerts@infrastructure-damage.local

# Google Maps API
GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# Model Configuration
MODEL_PATH=model/trained_models/infrastructure_damage/weights/best.pt
CONFIDENCE_THRESHOLD=0.5

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=False

# Upload Configuration
MAX_UPLOAD_SIZE=52428800
UPLOAD_DIRECTORY=uploads

# Alert Thresholds
ALERT_THRESHOLD_SEVERE=0.8
ALERT_THRESHOLD_MODERATE=0.5

# Contractor Configuration
CONTRACTOR_SERVICE_RADIUS_KM=25.0
MAX_CONTRACTOR_RECOMMENDATIONS=5

# Cost Multipliers
COST_MULTIPLIER_URBAN=1.1
COST_MULTIPLIER_RURAL=0.85

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Frontend
REACT_APP_API_URL=http://localhost:8000/api

# =====================================================
# AI CHAT ASSISTANT (Google Gemini)
# Get your free API key at: https://aistudio.google.com/app/apikey
# Free tier: 1,500 requests/day, 1M tokens/minute
# =====================================================
GEMINI_API_KEY=your_gemini_api_key_here

# =====================================================
# REAL-TIME TRAFFIC (TomTom)
# Get your free API key at: https://developer.tomtom.com/
# Free tier: 2,500 requests/day with map tile access
# Used for: Live traffic flow + incident tile overlays on the map
# =====================================================
REACT_APP_TOMTOM_KEY=your_tomtom_api_key_here
